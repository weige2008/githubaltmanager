# =========================================================
# GitHub Alt Manager - 配置示例
# 复制为 .env 并按需修改（所有变量均可通过环境变量注入）
# =========================================================

# ---- 服务监听 ----
GAM_HOST=0.0.0.0
GAM_PORT=8080
GAM_ENV=dev                # dev / prod

# ---- 数据库 ----
GAM_DB_PATH=./data/githubaltmanager.db

# ---- 安全：JWT 签名密钥（生产环境务必随机长字符串）----
# 生成命令：openssl rand -hex 32
GAM_JWT_SECRET=change-me-to-a-random-64-char-hex-string

# ---- 安全：master 密码 Argon2id 盐（hex, 16字节=32hex 字符）----
# 生成命令：openssl rand -hex 16
GAM_MASTER_SALT=change-me-to-a-random-32-char-hex-string

# Argon2id 参数（默认值即可，需要更高强度再调整）
GAM_ARGON2_ITER=3
GAM_ARGON2_MEM=65536
GAM_ARGON2_PARALLEL=2

# ---- GitHub API ----
GAM_GH_API=https://api.github.com
GAM_GH_TIMEOUT=20
GAM_GH_CONCURRENCY=8

# ---- 调度器时区 ----
GAM_TZ=Asia/Shanghai
