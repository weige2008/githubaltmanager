# =========================================================
# GitHub Alt Manager - 配置示例
# 复制为 .env 并按需修改（所有变量均可通过环境变量注入）
#
# 生产部署可不用此文件——直接用预编译二进制 + deploy.sh 自动生成
# =========================================================

# ---- 服务监听 ----
GAM_HOST=0.0.0.0
GAM_PORT=19527             # 默认使用不常用端口
GAM_ENV=prod               # dev / prod

# ---- 数据库 ----
GAM_DB_PATH=./data/githubaltmanager.db

# ---- 安全：JWT 签名密钥（生产环境务必随机长字符串）----
# 生成命令（Linux/macOS）：openssl rand -hex 32
# 生成命令（Windows PowerShell）：
#   -join ((1..64) | ForEach-Object { '{0:x}' -f (Get-Random -Max 16) })
GAM_JWT_SECRET=please-change-me-to-a-random-64-char-hex-string

# ---- 安全：master 密码 Argon2id 盐（hex, 16字节=32hex 字符）----
# 生成命令（Linux/macOS）：openssl rand -hex 16
GAM_MASTER_SALT=please-change-me-to-a-random-32-char-hex

# Argon2id 参数（默认值即可，需要更高强度再调整）
GAM_ARGON2_ITER=3
GAM_ARGON2_MEM=65536
GAM_ARGON2_PARALLEL=2

# ---- GitHub API ----
GAM_GH_API=https://api.github.com
GAM_GH_TIMEOUT=20
GAM_GH_CONCURRENCY=8

# ---- 调度器时区 ----
GAM_TZ=Asia/Shanghai

# ---- 前端静态目录（开发模式用；生产用预编译二进制已内嵌，留空即可）----
# GAM_STATIC_DIR=./frontend/dist
