# GitHub Alt Manager 配置文件
# 复制此文件为 .env 并修改参数

# 服务监听地址和端口（默认 0.0.0.0:8080）
GAM_HOST=0.0.0.0
GAM_PORT=8080
GAM_ENV=prod

# 数据库路径
GAM_DB_PATH=data/githubaltmanager.db

# JWT 密钥（必须设置，请更换为随机字符串）
GAM_JWT_SECRET=change-me-to-a-random-string

# 主密码加密盐（必须设置，请更换为随机 hex）
GAM_MASTER_SALT=change-me-to-random-hex

# GitHub API 配置
GAM_GH_API=https://api.github.com
GAM_GH_TIMEOUT=20
GAM_GH_CONCURRENCY=8

# 时区
GAM_TZ=Asia/Shanghai

# 主密码（用于自动解锁，可选）
# GAM_MASTER_PASSWORD=your-master-password
